<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <link rel="icon" type="image/svg+xml" href="~/brand/logo-tdl-moto.svg" asp-append-version="true" />
    <title>@(ViewBag.Title != null ? ViewBag.Title + " - " : "")TDL MOTO Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Source+Sans+3:wght@500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">    
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />    
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open bg-body-tertiary">
    <div class="app-wrapper">
        @await Html.PartialAsync("_Header")
        @await Html.PartialAsync("_Sidebar")        
        <main class="app-main">
            @if (IsSectionDefined("PageToolBar"))
            {
                <div class="app-content-header border-bottom">
                    <div class="container-fluid py-2 py-md-3">
                        <div class="d-flex flex-wrap justify-content-end align-items-center gap-2">
                            @await RenderSectionAsync("PageToolBar", required: false)
                        </div>
                    </div>
                </div>
            }
            <div class="app-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </main>
        @await Html.PartialAsync("_Footer")        
    </div>
    <button id="scrollToTop" onclick="window.scrollTo(0,0)">
        <i class="bi bi-arrow-up-circle"></i>
    </button>
    <div class="modal fade" id="dialogModal" tabindex="-1" aria-hidden="true" style="display:none;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">                
            </div>
        </div>
    </div>
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/l10n/vn.js"></script>    
    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/lib/adminlte/js/adminlte.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {            
            flatpickr(".date-picker", {
                dateFormat: "d/m/Y",
                locale: "vn",
                allowInput: false
            });
            document.querySelectorAll(".money-input").forEach(initMoneyInput);
            document.querySelectorAll(".open-modal").forEach(element => {                
                 element.addEventListener("click", function (e) {                    
                    openModal(e, this);
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>