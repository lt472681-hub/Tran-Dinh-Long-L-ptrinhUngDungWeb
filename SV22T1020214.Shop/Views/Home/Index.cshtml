@{
    ViewData["Title"] = "Trang chủ";
    var products = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    string[] icons = { "bi-speedometer2", "bi-truck-front-fill", "bi-fuel-pump", "bi-gear-wide-connected", "bi-shield-check", "bi-stars", "bi-award", "bi-wrench-adjustable", "bi-lightning-charge", "bi-geo-alt" };
}

<section class="home-hero-market mb-0">
    <div class="home-hero-market__mesh" aria-hidden="true"></div>
    <div class="home-hero-market__decor" aria-hidden="true">
        <span class="home-hero-market__blob home-hero-market__blob--a"></span>
        <span class="home-hero-market__blob home-hero-market__blob--b"></span>
        <span class="home-hero-market__blob home-hero-market__blob--c"></span>
        <span class="home-hero-market__spark home-hero-market__spark--1"></span>
        <span class="home-hero-market__spark home-hero-market__spark--2"></span>
        <span class="home-hero-market__spark home-hero-market__spark--3"></span>
    </div>
    <div class="container home-hero-market__inner">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-5 order-2 order-lg-1">
                <span class="home-hero-market__badge"><i class="bi bi-lightning-charge-fill"></i> Showroom TDL MOTO</span>
                <h1 class="home-hero-market__title">
                    <span class="home-hero-market__title-line">Cảm hứng côn tay</span>
                    <span class="home-hero-market__title-line home-hero-market__title-line--2"><span class="home-hero-market__accent">xe máy chọn lọc — đúng gu bạn</span></span>
                </h1>
                <p class="home-hero-market__lead">Xe qua kiểm định PDI, hồ sơ minh bạch, hỗ trợ trả góp và giao xe toàn quốc — từ lúc xem xe đến khi bạn lăn bánh.</p>
                <div class="home-hero-market__actions d-flex flex-wrap gap-2">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-grid-3x3-gap me-2"></i>Xem xe có sẵn
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary btn-lg px-4">
                        <i class="bi bi-calendar2-check me-2"></i>Đặt lịch xem xe
                    </a>
                </div>
            </div>
            <div class="col-lg-7 order-1 order-lg-2">
                <div class="home-hero-visual home-hero-visual--bleed home-hero-visual--photo reveal" role="img" aria-label="Banner xe máy TDL MOTO">
                    <div class="home-hero-visual__media">
                        <div id="homeHeroCarousel"
                             class="carousel slide carousel-fade home-hero-carousel"
                             data-bs-pause="hover"
                             aria-roledescription="carousel"
                             aria-label="Ảnh nổi bật showroom">
                            <div class="carousel-inner home-hero-carousel__inner">
                                <div class="carousel-item active">
                                    <img class="d-block w-100 home-hero-carousel__img"
                                         src="~/banner/moto_banner.png"
                                         asp-append-version="true"
                                         width="1200"
                                         height="675"
                                         loading="eager"
                                         decoding="async"
                                         alt="Xe máy sport tại TDL MOTO" />
                                </div>
                                <div class="carousel-item">
                                    <img class="d-block w-100 home-hero-carousel__img"
                                         src="~/banner/moto_banner1.png"
                                         asp-append-version="true"
                                         width="1200"
                                         height="675"
                                         loading="lazy"
                                         decoding="async"
                                         alt="Cảm hứng côn tay — TDL MOTO" />
                                </div>
                            </div>
                        </div>
                        <span class="home-hero-visual__vignette" aria-hidden="true"></span>
                        <span class="home-hero-visual__shine" aria-hidden="true"></span>
                        <span class="home-hero-visual__grain" aria-hidden="true"></span>
                        <div class="home-hero-carousel__ui">
                            <div class="carousel-indicators home-hero-carousel__dots">
                                <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Ảnh 1"></button>
                                <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="1" aria-label="Ảnh 2"></button>
                            </div>
                            <button class="carousel-control-prev home-hero-carousel__ctrl home-hero-carousel__ctrl--prev" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Ảnh trước</span>
                            </button>
                            <button class="carousel-control-next home-hero-carousel__ctrl home-hero-carousel__ctrl--next" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Ảnh sau</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-section--usp py-4 py-lg-5">
    <div class="container">
        <div class="row g-3 g-md-4">
            <div class="col-md-4">
                <div class="home-usp-card reveal">
                    <div class="home-usp-card__icon"><i class="bi bi-patch-check"></i></div>
                    <h3>Kiểm định &amp; minh bạch</h3>
                    <p>Máy, khung, số km và lịch sử bảo dưỡng được rà soát trước khi lên sàn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="home-usp-card reveal reveal--delay-1">
                    <div class="home-usp-card__icon"><i class="bi bi-truck"></i></div>
                    <h3>Giao xe &amp; hỗ trợ đăng ký</h3>
                    <p>Đồng hành giấy tờ sang tên — giao xe tận nơi theo lịch, cập nhật tiến độ rõ ràng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="home-usp-card reveal reveal--delay-2">
                    <div class="home-usp-card__icon"><i class="bi bi-bank"></i></div>
                    <h3>Tư vấn tài chính</h3>
                    <p>Gói trả góp, bảo hiểm và phụ kiện — tư vấn đúng nhu cầu, không ép mua.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-process-tdl py-5 border-bottom" style="border-color: var(--border) !important;">
    <div class="container">
        <div class="text-center mb-4">
            <span class="home-testimonials__eyebrow">Quy trình rõ ràng</span>
            <h2 class="h3 fw-bold mb-2 font-serif">4 bước sở hữu xe máy tại TDL MOTO</h2>
            <p class="text-muted mb-0 mx-auto" style="max-width: 560px;">Từ tư vấn online đến bàn giao — minh bạch từng bước.</p>
        </div>
        <div class="row g-3 g-lg-4">
            <div class="col-6 col-lg-3">
                <div class="tdl-step-card h-100 p-3 p-lg-4 rounded-4 border text-center" style="background: var(--surface-elevated); border-color: var(--border) !important;">
                    <span class="tdl-step-card__num d-inline-flex align-items-center justify-content-center rounded-circle mb-3 fw-bold" style="width:2.5rem;height:2.5rem;background:linear-gradient(135deg,#fb923c,var(--primary));color:#0c0e12;">1</span>
                    <h3 class="h6 fw-bold">Chọn xe &amp; báo giá</h3>
                    <p class="small text-muted mb-0">Xem kho online, so sánh phân khúc — nhận báo giá và gói vay gợi ý.</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="tdl-step-card h-100 p-3 p-lg-4 rounded-4 border text-center" style="background: var(--surface-elevated); border-color: var(--border) !important;">
                    <span class="tdl-step-card__num d-inline-flex align-items-center justify-content-center rounded-circle mb-3 fw-bold" style="width:2.5rem;height:2.5rem;background:linear-gradient(135deg,#fb923c,var(--primary));color:#0c0e12;">2</span>
                    <h3 class="h6 fw-bold">Xem xe thực tế</h3>
                    <p class="small text-muted mb-0">Đặt lịch tại showroom — kiểm tra máy, vỏ và phụ kiện cùng chuyên viên.</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="tdl-step-card h-100 p-3 p-lg-4 rounded-4 border text-center" style="background: var(--surface-elevated); border-color: var(--border) !important;">
                    <span class="tdl-step-card__num d-inline-flex align-items-center justify-content-center rounded-circle mb-3 fw-bold" style="width:2.5rem;height:2.5rem;background:linear-gradient(135deg,#fb923c,var(--primary));color:#0c0e12;">3</span>
                    <h3 class="h6 fw-bold">Cọc &amp; hồ sơ</h3>
                    <p class="small text-muted mb-0">Ký hợp đồng, hỗ trợ trả góp và chuẩn bị giấy tờ sang tên.</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="tdl-step-card h-100 p-3 p-lg-4 rounded-4 border text-center" style="background: var(--surface-elevated); border-color: var(--border) !important;">
                    <span class="tdl-step-card__num d-inline-flex align-items-center justify-content-center rounded-circle mb-3 fw-bold" style="width:2.5rem;height:2.5rem;background:linear-gradient(135deg,#fb923c,var(--primary));color:#0c0e12;">4</span>
                    <h3 class="h6 fw-bold">Nhận xe &amp; bảo hành</h3>
                    <p class="small text-muted mb-0">Bàn giao, hướng dẫn bảo dưỡng — theo dõi hậu mãi sau mua.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-section--promo-moto py-4" style="background: linear-gradient(90deg, rgba(232,93,4,0.08), transparent 40%, rgba(251,191,36,0.06));">
    <div class="container">
        <div class="row align-items-center g-3">
            <div class="col-lg-8">
                <h2 class="h5 fw-bold mb-1 font-serif">Tin khuyến mãi</h2>
                <p class="text-muted small mb-0">Ưu đãi phụ kiện, bảo dưỡng miễn phí lần đầu hoặc hỗ trợ lệ phí trước bạ cho một số dòng xe — liên hệ hotline để được cập nhật mới nhất.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-controller="Home" asp-action="Contact" class="btn btn-primary rounded-pill px-4"><i class="bi bi-chat-dots me-2"></i>Nhận ưu đãi</a>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-testimonials py-5 border-bottom" style="border-color: var(--border) !important;">
    <div class="container">
        <div class="text-center mb-4">
            <span class="home-testimonials__eyebrow">Khách hàng nói gì</span>
            <h2 class="h3 fw-bold mb-2 font-serif">Nhận xét từ khách hàng</h2>
            <p class="text-muted mb-0 mx-auto" style="max-width: 520px;">Trải nghiệm thực tế sau khi xem xe và nhận xe tại showroom TDL MOTO.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <article class="home-testimonial-card reveal">
                    <div class="home-testimonial-card__stars" aria-hidden="true">★★★★★</div>
                    <p class="home-testimonial-card__quote mb-0">“Tư vấn rõ ràng, xe đúng mô tả — giao xe đúng hẹn, không phát sinh chi phí lạ.”</p>
                    <footer class="home-testimonial-card__meta mt-3 pt-3 border-top" style="border-color: rgba(148,163,184,0.35) !important;">
                        <strong>Anh Minh</strong>
                        <span class="text-muted small d-block">Honda Winner X</span>
                    </footer>
                </article>
            </div>
            <div class="col-md-4">
                <article class="home-testimonial-card reveal reveal--delay-1">
                    <div class="home-testimonial-card__stars" aria-hidden="true">★★★★★</div>
                    <p class="home-testimonial-card__quote mb-0">“Hồ sơ minh bạch, được đi cùng kiểm tra kỹ thuật trước khi cọc — rất yên tâm.”</p>
                    <footer class="home-testimonial-card__meta mt-3 pt-3 border-top" style="border-color: rgba(148,163,184,0.35) !important;">
                        <strong>Chị Lan</strong>
                        <span class="text-muted small d-block">Yamaha NVX</span>
                    </footer>
                </article>
            </div>
            <div class="col-md-4">
                <article class="home-testimonial-card reveal reveal--delay-2">
                    <div class="home-testimonial-card__stars" aria-hidden="true">★★★★☆</div>
                    <p class="home-testimonial-card__quote mb-0">“Hỗ trợ trả góp nhanh, hotline phản hồi trong ngày — cả gia đình đều hài lòng.”</p>
                    <footer class="home-testimonial-card__meta mt-3 pt-3 border-top" style="border-color: rgba(148,163,184,0.35) !important;">
                        <strong>Anh Tuấn</strong>
                        <span class="text-muted small d-block">Honda SH</span>
                    </footer>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-promo-strip py-3">
    <div class="container">
        <div class="home-promo-strip__inner d-flex flex-wrap align-items-center justify-content-between gap-3 rounded-4 px-4 py-3 home-promo-strip--shimmer">
            <div class="d-flex align-items-center gap-3">
                <span class="home-promo-strip__icon"><i class="bi bi-percent"></i></span>
                <div>
                    <strong class="d-block">Ưu đãi tài chính tháng này</strong>
                    <span class="small text-muted">Hỗ trợ trả góp lãi suất ưu đãi cho một số dòng xe — xem chi tiết tại showroom.</span>
                </div>
            </div>
            <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-dark rounded-pill px-4">Tư vấn gói vay</a>
        </div>
    </div>
</section>

<section class="home-section py-4 border-bottom" style="border-color: var(--border) !important;">
    <div class="container">
        <h2 class="h5 fw-bold mb-3 font-serif">Cam kết TDL MOTO</h2>
        <div class="row g-3 g-md-4">
            <div class="col-6 col-md-3">
                <div class="home-mini-pill h-100 p-3 rounded-4 border bg-white">
                    <i class="bi bi-currency-dollar text-primary fs-4 mb-2 d-block"></i>
                    <h3 class="h6 fw-bold mb-1">Giá niêm rõ ràng</h3>
                    <p class="small text-muted mb-0">Báo giá theo tình trạng xe &amp; phụ kiện kèm theo.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="home-mini-pill h-100 p-3 rounded-4 border bg-white">
                    <i class="bi bi-file-earmark-text text-primary fs-4 mb-2 d-block"></i>
                    <h3 class="h6 fw-bold mb-1">Hồ sơ pháp lý</h3>
                    <p class="small text-muted mb-0">Hỗ trợ kiểm tra giấy tờ trước khi cọc.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="home-mini-pill h-100 p-3 rounded-4 border bg-white">
                    <i class="bi bi-tools text-primary fs-4 mb-2 d-block"></i>
                    <h3 class="h6 fw-bold mb-1">Bảo dưỡng sau mua</h3>
                    <p class="small text-muted mb-0">Gợi ý đại lý uy tín &amp; lịch bảo dưỡng.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="home-mini-pill h-100 p-3 rounded-4 border bg-white">
                    <i class="bi bi-headset text-primary fs-4 mb-2 d-block"></i>
                    <h3 class="h6 fw-bold mb-1">Hotline 8h–21h</h3>
                    <p class="small text-muted mb-0">Đặt lịch xem xe &amp; tư vấn nhanh.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-about-snippet py-4 border-top border-bottom" style="border-color: var(--border) !important; background: linear-gradient(180deg, rgba(226,232,240,0.5) 0%, transparent 100%);">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h2 class="h4 fw-bold mb-2 font-serif">Về TDL MOTO</h2>
                <p class="text-muted mb-0" style="max-width: 640px;">TDL MOTO là showroom trực tuyến — tuyển chọn xe máy tay ga, xe số và xe côn, đã qua kiểm định. Chúng tôi tin mua xe là hành trình dài, nên mỗi bước đều minh bạch.</p>
            </div>
            <div class="col-lg-5 text-lg-end">
                <a asp-controller="Home" asp-action="About" class="btn btn-outline-primary rounded-pill px-4">Câu chuyện showroom <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-brands py-4 bg-white border-bottom" style="border-color: var(--border) !important;">
    <div class="container">
        <h2 class="h6 text-uppercase text-muted letter-spacing fw-bold mb-3">Hãng &amp; phân khúc gợi ý</h2>
        <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start">
            <a asp-controller="Product" asp-action="Index" asp-route-search="tay ga" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Tay ga</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="xe số" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Xe số</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="côn tay" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Côn tay</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="phân khối lớn" class="btn btn-outline-secondary rounded-pill btn-sm px-3">PKL</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="điện" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Xe điện</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="Honda" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Honda</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="Yamaha" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Yamaha</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="Suzuki" class="btn btn-outline-secondary rounded-pill btn-sm px-3">Suzuki</a>
        </div>
    </div>
</section>

<section class="home-section home-cat-rail-section py-3">
    <div class="container home-cat-rail-wrap">
        <div class="home-cat-rail reveal-stagger">
            <a asp-controller="Product" asp-action="Index" asp-route-search="xe mới" class="home-cat-rail__chip reveal"><i class="bi bi-stars"></i> Xe mới về</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="giá tốt" class="home-cat-rail__chip reveal"><i class="bi bi-tag"></i> Giá tốt</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="gia đình" class="home-cat-rail__chip reveal"><i class="bi bi-people"></i> Gia đình</a>
            <a asp-controller="Product" asp-action="Index" class="home-cat-rail__chip reveal"><i class="bi bi-fire"></i> Xem tất cả</a>
        </div>
    </div>
</section>

<section class="home-section home-section--cream py-5">
    <div class="container">
        <h2 class="section-title">Vì sao chọn TDL MOTO</h2>
        <p class="text-muted mb-4" style="max-width: 640px;">Đội ngũ am hiểu thị trường ô tô — đồng hành từ xem xe, thử xe đến bàn giao.</p>
        <div class="row g-4 home-why-grid">
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal">
                    <div class="home-why-item__icon"><i class="bi bi-person-badge"></i></div>
                    <h3 class="h6 fw-bold">Tư vấn 1:1</h3>
                    <p class="small text-muted mb-0">Ngân sách, nhu cầu chở người &amp; nhiên liệu — gợi ý phân khúc phù hợp.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal reveal--delay-1">
                    <div class="home-why-item__icon"><i class="bi bi-search"></i></div>
                    <h3 class="h6 fw-bold">Kiểm tra kỹ thuật</h3>
                    <p class="small text-muted mb-0">Checklist động cơ, khung gầm và lịch bảo dưỡng trước khi niêm yết.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal reveal--delay-2">
                    <div class="home-why-item__icon"><i class="bi bi-shield-lock"></i></div>
                    <h3 class="h6 fw-bold">An tâm pháp lý</h3>
                    <p class="small text-muted mb-0">Hỗ trợ rà soát hồ sơ, cảnh báo rủi ro thường gặp.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal reveal--delay-3">
                    <div class="home-why-item__icon"><i class="bi bi-geo-alt"></i></div>
                    <h3 class="h6 fw-bold">Toàn quốc</h3>
                    <p class="small text-muted mb-0">Giao xe &amp; hỗ trợ logistics theo từng tỉnh thành.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container py-4">
    @if (categories.Any())
    {
        <section class="home-section home-section--categories mb-5 pt-2">
            <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
                <div>
                    <h2 class="section-title mb-1">Danh mục theo dòng xe</h2>
                    <p class="text-muted small mb-0">Chọn nhanh theo nhu cầu — cập nhật thường xuyên.</p>
                </div>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill">
                    Xe có sẵn <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="home-category-grid row g-3 g-md-4 reveal-stagger">
                @for (int i = 0; i < categories.Count && i < 6; i++)
                {
                    var cat = categories[i];
                    <div class="col-6 col-sm-4 col-md-3 col-xl-2">
                        <a class="category-card category-card--home d-flex flex-column align-items-center justify-content-center h-100 reveal text-decoration-none" asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.CategoryID">
                            <span class="category-card--home__icon-wrap">
                                <i class="bi @icons[i % icons.Length]" aria-hidden="true"></i>
                            </span>
                            <h6 class="category-card--home__title mb-0">@cat.CategoryName</h6>
                        </a>
                    </div>
                }
            </div>
        </section>
    }

    <section class="home-section mb-5">
        <h2 class="section-title">Gợi ý phân khúc</h2>
        <p class="text-muted mb-4" style="max-width: 560px;">Ba hướng phổ biến — bấm để xem xe gợi ý trong kho.</p>
        <div class="row g-3 g-lg-4">
            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" asp-route-search="sedan" class="home-inspire-card home-inspire-card--a reveal d-flex flex-column justify-content-end">
                    <span class="home-inspire-card__label">Êm ái</span>
                    <h3>Sedan &amp; cỡ D</h3>
                    <p>Đi làm hàng ngày, tiết kiệm nhiên liệu — lựa chọn an toàn cho gia đình nhỏ.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" asp-route-search="SUV" class="home-inspire-card home-inspire-card--b reveal reveal--delay-1 d-flex flex-column justify-content-end">
                    <span class="home-inspire-card__label">Đa dụng</span>
                    <h3>SUV &amp; crossover</h3>
                    <p>Gầm cao, không gian rộng — phù hợp du lịch cuối tuần.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" asp-route-search="điện" class="home-inspire-card home-inspire-card--c reveal reveal--delay-2 d-flex flex-column justify-content-end">
                    <span class="home-inspire-card__label">Tương lai</span>
                    <h3>Xe hybrid &amp; điện</h3>
                    <p>Tối ưu chi phí vận hành — giảm phát thải trong phố.</p>
                </a>
            </div>
        </div>
    </section>

    <section class="home-section mb-5">
        <div class="row g-3 reveal-stagger">
            <div class="col-lg-6">
                <div class="reveal h-100">
                    <a asp-controller="Product" asp-action="Index" class="home-mid-banner home-mid-banner--run d-block text-decoration-none h-100">
                        <div class="home-mid-banner__content">
                            <span class="small text-uppercase opacity-75">Xe mới cập nhật</span>
                            <h3 class="fw-bold mb-2 mt-1">Bảng giá niêm yết tuần</h3>
                            <p class="mb-3 small">Các mẫu xe vừa về kho — ưu đãi theo từng dòng</p>
                            <span class="btn btn-sm fw-semibold rounded-pill">Xem danh sách <i class="bi bi-arrow-right ms-1"></i></span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="reveal h-100">
                    <a asp-controller="Account" asp-action="Register" class="home-mid-banner home-mid-banner--court d-block text-decoration-none h-100">
                        <div class="home-mid-banner__content">
                            <span class="small text-uppercase">Khách hàng</span>
                            <h3 class="fw-bold mb-2 mt-1">Ưu đãi thành viên mới</h3>
                            <p class="mb-3 small">Đăng ký để nhận báo giá &amp; lịch lái thử sớm nhất</p>
                            <span class="btn btn-sm fw-semibold rounded-pill">Đăng ký miễn phí <i class="bi bi-arrow-right ms-1"></i></span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section mb-5">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h2 class="section-title mb-1">Xe được quan tâm</h2>
                <p class="text-muted small mb-0">Những mẫu xe đang được xem nhiều gần đây.</p>
            </div>
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>
        @if (products.Any())
        {
            <div class="row g-3 reveal-stagger">
                @foreach (var p in products)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card reveal h-100">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductID">
                                <div class="card-img-wrap">
                                    <img src="@(string.IsNullOrEmpty(p.Photo) ? "/image_chung/products/noproduct.svg" : "/image_chung/products/" + p.Photo)"
                                         alt="@p.ProductName" />
                                </div>
                            </a>
                            <div class="card-body">
                                <a class="product-name" asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductID">@p.ProductName</a>
                                <div class="product-price">@p.Price.ToString("N0") đ</div>
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="productId" value="@p.ProductID" />
                                    <button type="submit" class="btn btn-add-cart w-100">
                                        <i class="bi bi-cart-plus me-1"></i>Đặt cọc / Thêm
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 px-3 rounded-4 border border-dashed" style="border-color: var(--border) !important; background: var(--surface);">
                <i class="bi bi-inboxes fs-1 text-muted mb-2 d-block"></i>
                <p class="text-muted mb-3 mb-md-0">Chưa có xe nổi bật. Khám phá kho xe hoặc quay lại sau nhé.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-3">Đến danh sách xe</a>
            </div>
        }
    </section>

    <section class="home-section home-section--cream py-4 rounded-4 mb-4 px-3 px-md-4">
        <h2 class="section-title">Mẹo chọn xe</h2>
        <p class="text-muted mb-3">Gợi nhanh trước khi quyết định — luôn xem lịch bảo dưỡng và biên bản kiểm định.</p>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="p-3 rounded-3 border bg-white h-100">
                    <h3 class="h6 fw-bold text-primary">Lần đầu mua xe</h3>
                    <p class="small text-muted mb-0">Ưu tiên chi phí vận hành &amp; bảo hiểm — chọn phân khúc phù hợp đường phố Việt Nam.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-3 border bg-white h-100">
                    <h3 class="h6 fw-bold text-primary">Xe gia đình</h3>
                    <p class="small text-muted mb-0">Kiểm tra không gian hàng ghế sau, cốp và túi khí — đủ an toàn cho trẻ nhỏ.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-3 border bg-white h-100">
                    <h3 class="h6 fw-bold text-primary">Đổi xe</h3>
                    <p class="small text-muted mb-0">Định giá xe cũ, cân đối trả góp — TDL MOTO hỗ trợ tư vấn minh bạch.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section mb-5">
        <h2 class="section-title">Câu hỏi thường gặp</h2>
        <div class="accordion accordion-flush home-faq rounded-4 border overflow-hidden" id="faqHome">
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">Làm sao biết xe đủ điều kiện?</button>
                </h3>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqHome">
                    <div class="accordion-body text-muted small">Xem báo cáo kiểm định, số km và ảnh chi tiết trên trang sản phẩm. Cần hỗ trợ thêm, nhắn TDL MOTO — chúng tôi tư vấn theo ngân sách và nhu cầu sử dụng.</div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">Thời gian giao xe?</button>
                </h3>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqHome">
                    <div class="accordion-body text-muted small">Nội thành thường 3–7 ngày sau khi hoàn tất cọc &amp; thủ tục; tỉnh khác theo lịch vận chuyển — báo cụ thể khi chốt đơn.</div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">Có hỗ trợ trả góp?</button>
                </h3>
                <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqHome">
                    <div class="accordion-body text-muted small">Có — chúng tôi kết nối đối tác tài chính; điều kiện phụ thuộc hồ sơ và từng dòng xe. Tư vấn miễn phí tại showroom hoặc qua hotline.</div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section--cream home-section--steps py-5 rounded-4 mb-4 px-3 px-md-4">
        <div class="container-fluid px-0">
            <h2 class="section-title">Quy trình 4 bước</h2>
            <p class="text-muted mb-4 home-steps__lead">Từ chọn xe đến nhận chìa khóa — rõ ràng, minh bạch.</p>
            <div class="home-steps home-steps--four" role="list">
                <div class="home-step reveal" role="listitem">
                    <span class="home-step__num" aria-hidden="true">1</span>
                    <div>
                        <h4>Chọn xe</h4>
                        <p>Xem catalog, so sánh giá &amp; đặt lịch xem xe tận nơi hoặc online.</p>
                    </div>
                </div>
                <div class="home-step reveal reveal--delay-1" role="listitem">
                    <span class="home-step__num" aria-hidden="true">2</span>
                    <div>
                        <h4>Cọc &amp; hồ sơ</h4>
                        <p>Giữ chỗ, ký hợp đồng mua bán — rà soát giấy tờ pháp lý cùng chuyên viên.</p>
                    </div>
                </div>
                <div class="home-step reveal reveal--delay-2" role="listitem">
                    <span class="home-step__num" aria-hidden="true">3</span>
                    <div>
                        <h4>Kiểm tra cuối</h4>
                        <p>Kiểm tra kỹ thuật &amp; phụ kiện — bàn giao biên bản bàn giao xe.</p>
                    </div>
                </div>
                <div class="home-step reveal reveal--delay-3" role="listitem">
                    <span class="home-step__num" aria-hidden="true">4</span>
                    <div>
                        <h4>Giao xe</h4>
                        <p>Nhận xe tại showroom hoặc giao tận nhà — hỗ trợ sau bán theo chính sách.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-bottom-cta home-bottom-cta--tdl-moto text-center rounded-4 overflow-hidden mb-2 reveal">
        <div class="home-bottom-cta__mesh" aria-hidden="true"></div>
        <div class="home-bottom-cta__glow home-bottom-cta__glow--1" aria-hidden="true"></div>
        <div class="home-bottom-cta__glow home-bottom-cta__glow--2" aria-hidden="true"></div>
        <div class="home-bottom-cta__inner py-5 px-3">
            <h3 class="fw-bold mb-2 font-serif home-bottom-cta__title">Sẵn sàng lên đường cùng TDL MOTO?</h3>
            <p class="mb-4 text-muted-cta mx-auto home-bottom-cta__sub" style="max-width:520px;">Hàng trăm lựa chọn đã kiểm định — tư vấn tài chính &amp; giao xe linh hoạt. Đặt lịch ngay hôm nay.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg fw-semibold px-5 home-cta-shop-btn">
                <i class="bi bi-truck-front-fill me-2"></i>Xem kho xe
            </a>
        </div>
    </section>
</div>
